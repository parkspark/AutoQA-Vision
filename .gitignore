# ============================================================
# DNF Vision — .gitignore
# 원칙: 코드·문서·가벼운 포트폴리오 자산만 올린다.
# 대용량 데이터·모델 가중치·생성물·환경은 제외
# (재생성 가능하거나 GitHub 100MB 파일 한도 초과).
# 주의: .gitignore는 '같은 줄 끝 주석'을 지원하지 않으므로 주석은 별도 줄에만 둔다.
# ============================================================

# ---- Python 환경 / 캐시 ----
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.ipynb_checkpoints/

# ---- Node / Next.js (web/frontend/.gitignore 와 중복 안전망) ----
node_modules/
.next/
out/
*.tsbuildinfo
next-env.d.ts

# ---- 대용량 데이터셋 (파이프라인으로 재생성 가능) ----
# datasets/ = 5GB+ (원본 영상 + YOLO 데이터셋)
datasets/
# labeled/ = 600MB+ (원본 스크린샷 + labelme JSON)
# 웹앱 '샘플로 탐지' 데모용 스크린샷 8장만 예외로 포함 (sorted glob 상위 8개)
labeled/*
!labeled/ScreenShot2024_0304_084801113.jpg
!labeled/ScreenShot2024_0304_085326839.jpg
!labeled/ScreenShot2024_0304_090315563.jpg
!labeled/ScreenShot2024_0304_091035562.jpg
!labeled/ScreenShot2024_0304_101601331.jpg
!labeled/ScreenShot2024_0304_115450606.jpg
!labeled/ScreenShot2024_0304_125900883.jpg
!labeled/ScreenShot2024_0304_132601889.jpg
# DF_character_dataset/ = 합성 소스 스프라이트
DF_character_dataset/
# reviews/ = 라벨 검수 사이클 산출물
reviews/

# ---- 모델 / 학습 산출물 ----
# runs/ = 학습 결과 + 가중치. 현역 v3 추론 가중치(best.pt, 19MB) 1개만 예외로 포함
# (부모 폴더가 통째로 무시되면 내부 파일을 되살릴 수 없어 단계별 화이트리스트 필수)
runs/*
!runs/df_yolo11s_1280_v3/
runs/df_yolo11s_1280_v3/*
!runs/df_yolo11s_1280_v3/weights/
runs/df_yolo11s_1280_v3/weights/*
!runs/df_yolo11s_1280_v3/weights/best.pt
# models/ = 사전학습 가중치
models/
*.pt
*.pth
*.onnx
*.engine
*.npy

# ---- 로그 / 백업 / 임시 ----
logs/
backups/
web/backend/_work/
*.log

# ---- 대용량 영상 (240MB mp4는 GitHub가 거부) ----
# 작은 데모 1개만 예외로 포함
*.mp4
*.avi
*.mov
*.mkv
!outputs/track_color_demo.mp4

# 큰 압축 백업
*.zip

# ---- 로컬 도구 / 비밀값 ----
# .claude/ = 로컬 실행 설정(launch.json 등, 머신 경로 포함)
.claude/
.env
.env.*
*.local

# ---- 에디터 / OS ----
.vscode/
.idea/
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- 가중치 화이트리스트 안전망 ----
# 위 전역 *.pt 규칙보다 우선해 v3 추론 가중치만 되살린다 (클론 후 즉시 추론용)
!runs/df_yolo11s_1280_v3/weights/best.pt

# ============================================================
# 의도적으로 '포함'되는 것 (위 규칙에 안 걸림):
#   scripts/  web/  *.py  *.md  requirements.txt  df_dataset.yaml  *.bat
#   reports/*.ipynb 및 reports/*_assets/*.png
#   outputs/*.json · outputs/track_color_demo.mp4
#   hardware/*.jpg
#   runs/df_yolo11s_1280_v3/weights/best.pt (현역 추론 가중치 19MB)
# ============================================================
